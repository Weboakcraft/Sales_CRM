/* ================= PAGINATION (measurement-driven) ================= */
function paginate(C){
  const M = document.getElementById('measurePage');
  const pxmm = M.getBoundingClientRect().width / 210;
  const cs = getComputedStyle(M);
  const padT = parseFloat(cs.paddingTop), padB = parseFloat(cs.paddingBottom);
  const innerH = 296*pxmm - padT - padB - 1*pxmm;   // 1mm safety margin

  const rowsArr = C.rows.length ? C.rows.map(rowHTML)
    : [`<tr><td colspan="8" style="text-align:center; color:var(--muted); padding:8mm">Add products from the panel on the left</td></tr>`];

  /* pass 1: measure header, each row, and each bottom block separately */
  M.innerHTML = fullHeadHTML('')
    + `<table class="items" id="mTbl">${THEAD}<tbody>${rowsArr.join('')}</tbody></table>`
    + `<div id="mB1">${totalsMainHTML(C)}</div>`
    + `<div id="mB2">${termsSigHTML()}</div>`
    + `<div class="foot-strip" id="mFoot">x</div>`;
  const mTop = M.getBoundingClientRect().top + padT;
  const tbl = M.querySelector('#mTbl');
  const trs = [...tbl.querySelectorAll('tbody tr')];
  const headH = tbl.getBoundingClientRect().top - mTop;                    // full header incl. margins
  const theadH = trs[0].getBoundingClientRect().top - tbl.getBoundingClientRect().top;
  const rowH = trs.map((tr,i)=> (i<trs.length-1 ? trs[i+1].getBoundingClientRect().top : tbl.getBoundingClientRect().bottom) - tr.getBoundingClientRect().top);
  const b1 = M.querySelector('#mB1'), b2 = M.querySelector('#mB2'), ft = M.querySelector('#mFoot');
  const b1H = b1.getBoundingClientRect().bottom - tbl.getBoundingClientRect().bottom;  // incl. top margin
  const b2H = b2.getBoundingClientRect().bottom - b1.getBoundingClientRect().bottom;   // incl. top margin
  const footH = ft.getBoundingClientRect().bottom - b2.getBoundingClientRect().bottom; // pinned footer

  /* pass 2: continuation header height */
  M.innerHTML = contHeadHTML('Page 2') + `<table class="items" id="mTbl2">${THEAD}</table>`;
  const contH = M.querySelector('#mTbl2').getBoundingClientRect().top - (M.getBoundingClientRect().top + padT);

  M.innerHTML = '';

  /* greedy packing — rows first, then the bottom blocks flow continuously:
     whatever fits stays on the current page; only the overflow moves on */
  const pages = [];
  let cur = {cont:false, rows:[], blocks:[]};
  let cap = innerH - headH - theadH - footH;
  let used = 0;
  rowsArr.forEach((_, i)=>{
    if(used + rowH[i] > cap && cur.rows.length){
      pages.push(cur);
      cur = {cont:true, rows:[], blocks:[]};
      cap = innerH - contH - theadH - footH;
      used = 0;
    }
    cur.rows.push(i); used += rowH[i];
  });
  let remain = cap - used;
  [['tot', b1H], ['terms', b2H]].forEach(([key, h])=>{
    if(h > remain && (cur.rows.length || cur.blocks.length)){
      pages.push(cur);
      cur = {cont:true, rows:[], blocks:[]};
      remain = innerH - contH - footH;
    }
    cur.blocks.push(key); remain -= h;
  });
  pages.push(cur);
  return {pages, rowsArr};
}

/* ================= RENDER ================= */
function R(){
  document.getElementById('tbQno').textContent = fmtQno();
  const C = calc();
  const {pages, rowsArr} = paginate(C);
  const totalPages = pages.length + 1;   // + WHY OAKCRAFT

  let html = '';
  pages.forEach((p, idx)=>{
    const pageInfo = `Page ${idx+1} of ${totalPages}`;
    let inner = p.cont ? contHeadHTML(pageInfo) : fullHeadHTML(totalPages>2?pageInfo:'');
    if(p.rows.length){
      inner += `<table class="items">${THEAD}<tbody>${p.rows.map(i=>rowsArr[i]).join('')}</tbody></table>`;
      const isLastRowPage = p.rows[p.rows.length-1] === rowsArr.length-1;
      if(!isLastRowPage) inner += `<div class="tbl-cont-note">Continued on next page…</div>`;
    }
    (p.blocks || []).forEach(b=>{ inner += (b==='tot') ? totalsMainHTML(C) : termsSigHTML(); });
    if(idx < pages.length-1 && (!p.rows.length || p.rows[p.rows.length-1] === rowsArr.length-1) && (p.blocks||[]).length < 2 && !(p.blocks||[]).includes('terms')){
      inner += `<div class="tbl-cont-note">Continued on next page…</div>`;
    }
    inner += `<div class="pagefill"></div><div class="foot-strip">oakcraft.in · ${CO.email} · Manufacturer-Direct Since Day One</div>`;
    html += `<div class="pwrap"><div class="page inv-page">${inner}</div></div>`;
  });
  html += `<div class="pwrap"><div class="page" id="pageWhy">${whyHTML()}</div></div>`;
  document.getElementById('printArea').innerHTML = html;
  fitPreview();
}

/* ================= MOBILE FIT & VIEWS ================= */
const isMobile = () => window.matchMedia('(max-width:900px)').matches;
function fitPreview(){
  const mobile = isMobile() && !document.body.classList.contains('exporting');
  document.querySelectorAll('#printArea .pwrap').forEach(w=>{
    const p = w.querySelector('.page');
    if(mobile){
      const avail = w.clientWidth || document.getElementById('preview').clientWidth - 16;
      if(avail > 0 && p.offsetWidth > 0){
        const sc = Math.min(1, avail / p.offsetWidth);
        p.style.transform = `scale(${sc})`;
        w.style.height = (p.offsetHeight * sc) + 'px';
      }
    }else{
      p.style.transform = ''; w.style.height = '';
    }
  });
}
function setView(v){
  document.body.classList.toggle('mPreview', v === 'preview');
  document.getElementById('tabEdit').classList.toggle('active', v === 'edit');
  document.getElementById('tabPrev').classList.toggle('active', v === 'preview');
  if(v === 'preview'){ fitPreview(); window.scrollTo({top:0}); }
}
window.addEventListener('resize', fitPreview);
window.addEventListener('orientationchange', ()=> setTimeout(fitPreview, 250));

