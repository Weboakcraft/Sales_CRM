async function downloadPDF(){
  if(repMissing()) return;
  const btn = document.getElementById('dlBtn');
  btn.disabled = true; btn.textContent = 'Preparing PDF…';
  try{
    if(typeof html2pdf === 'undefined'){
      const bar = document.getElementById('pdfbar');
      bar.classList.add('show');
      document.getElementById('pdfmsg').textContent = 'PDF engine could not load in this viewer — use the Print button and choose "Save as PDF" instead.';
      document.getElementById('pdfOpen').style.display = 'none';
      return;
    }
    document.getElementById('pdfOpen').style.display = '';
    document.getElementById('pdfmsg').textContent = '✓ PDF generated.';
    if(!dateManual){ S.date = new Date().toISOString().slice(0,10); syncInputs(); }
    await reserveNumber();
    R();
    const fname = `OakCraft-ProForma-OAK-${FY}-${S.qno}.pdf`;
    document.body.classList.add('exporting');

    /* render EACH page separately — one page element = exactly one PDF page */
    const pageEls = [...document.querySelectorAll('#printArea .page')];
    let pdf = null;
    for(let i=0; i<pageEls.length; i++){
      if(i === 0){
        pdf = await html2pdf().set({
          margin: 0,
          image: {type:'jpeg', quality:0.92},
          html2canvas: {scale:2, useCORS:true, logging:false},
          jsPDF: {unit:'mm', format:'a4', orientation:'portrait'},
          pagebreak: {mode:['avoid-all']}
        }).from(pageEls[0]).toPdf().get('pdf');
      }else{
        const canvas = await html2pdf().set({
          html2canvas: {scale:2, useCORS:true, logging:false}
        }).from(pageEls[i]).toCanvas().get('canvas');
        const img = canvas.toDataURL('image/jpeg', 0.92);
        const h = Math.min(297, canvas.height * 210 / canvas.width);
        pdf.addPage('a4', 'portrait');
        pdf.addImage(img, 'JPEG', 0, 0, 210, h);
      }
    }
    document.body.classList.remove('exporting');

    const blob = pdf.output('blob');
    if(lastPdfUrl) URL.revokeObjectURL(lastPdfUrl);
    lastPdfUrl = URL.createObjectURL(blob);

    /* Path 1 — native download */
    try{
      const a = document.createElement('a');
      a.href = lastPdfUrl; a.download = fname;
      document.body.appendChild(a); a.click(); a.remove();
    }catch(e){}

    /* Path 2 — always offer Open PDF as backup */
    document.getElementById('pdfOpen').href = lastPdfUrl;
    document.getElementById('pdfbar').classList.add('show');
  }catch(e){
    document.body.classList.remove('exporting');
    window.print();   // final fallback
  }finally{
    btn.disabled = false; btn.textContent = '⤓ Download PDF';
    fitPreview();
  }
}
