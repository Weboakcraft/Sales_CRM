<script>
(function(){
  /* ⬇️ PASTE YOUR APPS SCRIPT WEB APP URL HERE (ends with /exec) */
  const GAS_URL = 'https://script.google.com/macros/s/AKfycbzIayCjJeyzojqJbZLijTo_cPy6YywZETtyuD3uaIZnw4fU7WwiPWKmgP81M8JeM0Dkvg/exec';

  const configured = GAS_URL.indexOf('XXXX') === -1;

  async function gas(action, payload){
    const res = await fetch(GAS_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'text/plain;charset=utf-8' },
      body: JSON.stringify(Object.assign({ action: action }, payload || {}))
    });
    const data = await res.json();
    if(!data.ok) throw new Error(data.error || 'Backend error');
    return data;
  }

  window.storage = {
    async get(key, shared){
      const r = await gas('storageGet', { key: key });
      if(!r.found) throw new Error('Key not found: ' + key);
      return { key: key, value: r.value, shared: !!shared };
    },
    async set(key, value, shared){
      await gas('storageSet', { key: key, value: value });
      return { key: key, value: value, shared: !!shared };
    }
  };

  function buildPayload(){
    const C = calc();
    return {
      qnoFormatted: fmtQno(),
      fy: FY,
      qno: S.qno,
      date: S.date,
      valid: S.valid,
      gst: S.gst,
      rep: S.rep,
      repPh: S.repPh,
      co: S.co,
      attn: S.attn,
      addr: S.addr,
      cgstin: S.cgstin,
      cph: S.cph,
      state: S.state,
      shipTo: S.shipTo,
      freightMode: S.freightMode,
      freight: C.fr,
      sub: C.sub,
      taxable: C.taxable,
      cgstAmt: C.cgst,
      sgstAmt: C.sgst,
      igstAmt: C.igst,
      roundoff: Number(C.roundoff.toFixed(2)),
      grand: C.grand,
      warranty: S.warranty,
      payTerms: S.payTerms,
      terms: S.terms,
      items: C.rows.map(function(r, i){
        return {
          line: i + 1, name: r.name, desc: r.desc, hsn: r.hsn,
          qty: r.qty, price: r.price, disc: r.disc || 0,
          net: Number(r.net.toFixed(2)), amt: Number(r.amt.toFixed(2)),
          del: r.del
        };
      })
    };
  }

  function setStatus(msg, ok){
    const el = document.getElementById('storeStatus');
    if(el){ el.textContent = msg; el.style.color = ok ? 'var(--ok)' : 'var(--err)'; }
  }

  const originalDownloadPDF = window.downloadPDF;
  window.downloadPDF = async function(){
    await originalDownloadPDF.apply(this, arguments);

    if(typeof repMissing === 'function' && repMissing()) return;
    if(!configured){
      setStatus('Google Sheets not connected yet — paste your Web App URL into the integration script.', false);
      return;
    }
    try{
      setStatus('Saving ' + fmtQno() + ' to Google Sheets…', true);
      const r = await gas('saveQuotation', { quotation: buildPayload() });
      setStatus('✓ ' + r.saved + ' saved to Google Sheets (' + r.items + ' item' + (r.items === 1 ? '' : 's') + ').', true);
    }catch(err){
      console.error('Sheets save failed:', err);
      setStatus('Could not save to Google Sheets: ' + err.message + ' — the PDF itself downloaded fine.', false);
    }
  };

  if(configured){
    initNumber();
  }else{
    setStatus('Google Sheets not connected — edit GAS_URL in the integration script at the bottom of this file.', false);
  }
})();
</script>

