<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OakCraft — Pro Forma Quotation Builder</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<style>
:root{
  --gold:#B4802F; --gold-deep:#9A6C24; --ink:#241A10; --ink-soft:#4A3B28;
  --paper:#FFFFFF; --cream:#F7F2E9; --cream-deep:#EFE6D5;
  --line:#E3D9C6; --line-dark:#C9B68E; --muted:#8A7B65; --ok:#2E7D32; --live:#3FA34D; --err:#B0442C;
}
*{box-sizing:border-box; margin:0; padding:0}
html,body{height:100%}
body{
  font-family:'Helvetica Neue', Helvetica, Arial, sans-serif;
  background:var(--cream); color:var(--ink); font-size:14px;
  -webkit-print-color-adjust:exact; print-color-adjust:exact;
}

/* ============ APP CHROME (never prints/exports) ============ */
#toolbar{
  position:fixed; top:0; left:0; right:0; height:58px; z-index:50;
  background:var(--ink); color:#F5EEDF; display:flex; align-items:center;
  gap:14px; padding:0 20px; box-shadow:0 2px 12px rgba(36,26,16,.25);
}
#toolbar .brand{font-family:Georgia,serif; font-size:17px; letter-spacing:.06em}
#toolbar .brand b{color:#D9AE5F}
#toolbar .qbadge{
  margin-left:6px; font-size:12px; letter-spacing:.14em; text-transform:uppercase;
  background:rgba(217,174,95,.14); border:1px solid rgba(217,174,95,.45);
  color:#E8C888; padding:5px 12px; border-radius:3px;
}
#toolbar .spacer{flex:1}
.btn{
  border:1px solid var(--gold); background:transparent; color:#E8C888;
  font-size:12px; letter-spacing:.12em; text-transform:uppercase;
  padding:9px 16px; cursor:pointer; border-radius:3px; transition:all .15s;
  font-family:inherit;
}
.btn:hover{background:rgba(217,174,95,.12)}
.btn.primary{background:var(--gold); color:#FFF; border-color:var(--gold)}
.btn.primary:hover{background:var(--gold-deep)}
.btn:disabled{opacity:.5; cursor:wait}
.btn:focus-visible{outline:2px solid #E8C888; outline-offset:2px}

#pdfbar{
  display:none; position:fixed; top:58px; left:0; right:0; z-index:49;
  background:#EAF4EA; border-bottom:1px solid #BFDCC0; color:#215723;
  padding:9px 20px; font-size:13px; align-items:center; gap:14px;
}
#pdfbar.show{display:flex}
#pdfbar a{color:#215723; font-weight:700; text-decoration:underline; cursor:pointer}
#pdfbar .close{margin-left:auto; cursor:pointer; border:none; background:none; color:#215723; font-size:16px}

#layout{display:flex; padding-top:58px; min-height:100vh}

/* ============ EDITOR SIDEBAR ============ */
#editor{
  width:392px; min-width:392px; background:#FDFBF7; border-right:1px solid var(--line);
  height:calc(100vh - 58px); overflow-y:auto; padding:18px 18px 60px;
}
.ed-sec{margin-bottom:22px}
.ed-sec h3{
  font-size:11px; letter-spacing:.18em; text-transform:uppercase; color:var(--gold-deep);
  border-bottom:1px solid var(--line); padding-bottom:7px; margin-bottom:12px; font-weight:600;
}
.f{margin-bottom:9px}
.f label{display:block; font-size:11px; color:var(--muted); margin-bottom:3px; letter-spacing:.04em}
.f label b{color:var(--err)}
.f input, .f select, .f textarea{
  width:100%; border:1px solid var(--line); border-radius:3px; padding:7px 9px;
  font-size:13px; font-family:inherit; background:#FFF; color:var(--ink);
}
.f input:focus, .f select:focus, .f textarea:focus{outline:none; border-color:var(--gold)}
.f input.err, .f select.err{border-color:var(--err); background:#FDF1EE}
.frow{display:flex; gap:8px}
.frow .f{flex:1}
.item-card{
  border:1px solid var(--line); border-left:3px solid var(--gold); border-radius:4px;
  padding:11px; margin-bottom:11px; background:#FFF;
}
.item-card .ic-head{display:flex; justify-content:space-between; align-items:center; margin-bottom:8px}
.item-card .ic-head span{font-size:11px; letter-spacing:.12em; color:var(--gold-deep); font-weight:600}
.item-card .rm{border:none; background:none; color:var(--err); cursor:pointer; font-size:11px; letter-spacing:.06em; text-transform:uppercase}
.photo-drop{display:flex; align-items:center; gap:9px; margin-top:6px}
.photo-drop img{width:44px; height:44px; object-fit:cover; border-radius:3px; border:1px solid var(--line)}
.photo-drop .ph-empty{
  width:44px; height:44px; border:1px dashed var(--line-dark); border-radius:3px;
  display:flex; align-items:center; justify-content:center; color:var(--muted); font-size:18px;
}
.photo-drop input[type=file]{font-size:11px; width:auto}
.addbtn{
  width:100%; border:1px dashed var(--gold); background:none; color:var(--gold-deep);
  padding:10px; border-radius:4px; cursor:pointer; font-size:12px; letter-spacing:.1em;
  text-transform:uppercase; font-family:inherit;
}
.addbtn:hover{background:rgba(180,128,47,.06)}
.hint{font-size:11px; color:var(--muted); line-height:1.5; margin-top:6px}
.hint.warn{color:var(--err); font-weight:600}

/* ============ PREVIEW ============ */
#preview{flex:1; overflow-y:auto; height:calc(100vh - 58px); padding:26px 30px 80px; display:flex; flex-direction:column; align-items:center}
#printArea{display:flex; flex-direction:column; gap:26px}

.page{
  width:210mm; min-height:296mm; background:var(--paper);
  box-shadow:0 4px 30px rgba(36,26,16,.16);
  padding:12mm 12mm 10mm; position:relative; display:flex; flex-direction:column;
  page-break-after:always; break-after:page;
}
.page:last-child{page-break-after:auto; break-after:auto}
#measurePage{position:absolute; left:-9999px; top:0; visibility:hidden; box-shadow:none}
body.exporting #printArea{gap:0; display:block}
body.exporting .page{box-shadow:none}

/* ---- Invoice pages ---- */
.doc-head{display:flex; justify-content:space-between; align-items:flex-start}
.doc-head img.logo{height:21mm; width:auto}
.doc-title{text-align:right}
.doc-title h1{
  font-family:Georgia,serif; font-weight:400; font-size:20px; letter-spacing:.32em;
  text-transform:uppercase; color:var(--ink); margin-bottom:4px;
}
.doc-title .qno{font-size:13px; color:var(--gold-deep); letter-spacing:.1em; font-weight:600}
.doc-title .dsub{font-size:10px; color:var(--muted); margin-top:1mm}
.gold-rule{height:2.5px; background:var(--gold); margin:4.5mm 0 0; position:relative}
.gold-rule:after{content:''; position:absolute; left:0; right:0; top:4.5px; height:1px; background:var(--line-dark)}

.cont-head{display:flex; justify-content:space-between; align-items:center}
.cont-head img{height:12mm}
.cont-head .ct{text-align:right}
.cont-head .ct .t{font-family:Georgia,serif; font-size:13px; letter-spacing:.26em; text-transform:uppercase; color:var(--ink)}
.cont-head .ct .s{font-size:10px; color:var(--gold-deep); letter-spacing:.1em; font-weight:600; margin-top:.6mm}

.meta-band{display:flex; justify-content:space-between; gap:8mm; margin-top:4.5mm}
.from-block{font-size:10px; line-height:1.55; color:var(--ink-soft); max-width:82mm}
.from-block b{font-family:Georgia,serif; font-size:13px; color:var(--ink); letter-spacing:.04em}
.meta-grid{display:grid; grid-template-columns:auto auto; gap:2px 14px; font-size:10.5px; align-content:start}
.meta-grid .k{color:var(--muted); text-transform:uppercase; letter-spacing:.1em; font-size:9px; padding-top:2px}
.meta-grid .v{font-weight:600; color:var(--ink); text-align:right}

.billto{
  margin-top:4.5mm; background:var(--cream); border:1px solid var(--line);
  border-left:3px solid var(--gold); padding:3.6mm 5mm; display:flex; justify-content:space-between; gap:6mm;
}
.billto .bt-l{font-size:11px; line-height:1.6}
.billto .lbl{font-size:9px; letter-spacing:.18em; text-transform:uppercase; color:var(--gold-deep); font-weight:700; margin-bottom:2px}
.billto b.cname{font-family:Georgia,serif; font-size:14px; color:var(--ink)}
.billto .bt-r{font-size:10.5px; text-align:right; line-height:1.7; color:var(--ink-soft); min-width:40mm}
.billto .bt-m{font-size:10.5px; line-height:1.6; border-left:1px solid var(--line-dark); padding-left:5mm; flex:1}

table.items{width:100%; border-collapse:collapse; margin-top:4.5mm; font-size:10px}
table.items thead th{
  background:var(--ink); color:#F0E6D2; font-weight:500; letter-spacing:.08em; text-transform:uppercase;
  font-size:8px; padding:2.5mm 1.8mm; text-align:left;
}
table.items thead th.r, table.items td.r{text-align:right}
table.items thead th.c, table.items td.c{text-align:center}
table.items tbody td{padding:1.9mm 1.8mm; border-bottom:1px solid var(--line); vertical-align:middle}
table.items td .iname{font-weight:700; color:var(--ink); font-size:10.5px}
table.items td .idesc{color:var(--muted); font-size:9px; margin-top:1px; line-height:1.4}
table.items td img.ithumb{width:17mm; height:17mm; object-fit:cover; border-radius:2px; border:1px solid var(--line); display:block}
table.items td .idel{font-size:9px; color:var(--ink-soft)}
.tbl-cont-note{font-size:8.5px; color:var(--muted); font-style:italic; text-align:right; margin-top:1.5mm; font-family:Georgia,serif}
.strike{text-decoration:line-through; color:var(--muted); font-size:8.5px; display:block}
.netrate{font-weight:600}

.tot-wrap{display:flex; gap:6mm; margin-top:4mm}
.tot-left{flex:1; font-size:10px}
.words-box{background:var(--cream); border:1px solid var(--line); padding:2.6mm 4mm; margin-bottom:2.4mm}
.words-box .lbl{font-size:8.5px; letter-spacing:.16em; text-transform:uppercase; color:var(--gold-deep); font-weight:700}
.words-box .w{font-family:Georgia,serif; font-style:italic; font-size:11px; margin-top:1mm; line-height:1.5}
.commit-grid{display:grid; grid-template-columns:1fr 1fr; gap:2mm 4mm; font-size:9.5px}
.commit-grid .cg{border:1px solid var(--line); padding:2mm 3mm}
.commit-grid .cg .k{font-size:8px; letter-spacing:.14em; text-transform:uppercase; color:var(--muted)}
.commit-grid .cg .v{font-weight:600; margin-top:.5mm; color:var(--ink)}
.tot-right{width:64mm; font-size:10.5px}
.tot-right .tr{display:flex; justify-content:space-between; padding:1.6mm 3mm; border-bottom:1px solid var(--line)}
.tot-right .tr .k{color:var(--ink-soft)}
.tot-right .tr .v{font-weight:600}
.tot-right .grand{
  background:var(--ink); color:#F5EEDF; padding:2.8mm 3mm; display:flex; justify-content:space-between;
  align-items:center; margin-top:1.5mm;
}
.tot-right .grand .k{font-size:9px; letter-spacing:.18em; text-transform:uppercase}
.tot-right .grand .v{font-family:Georgia,serif; font-size:16px; color:#E8C888}

.payrow{display:flex; gap:4mm; margin-top:2.4mm; border:1px solid var(--line); padding:2.6mm 3mm; align-items:center}
.payrow .pay-l{flex:1}
.payrow .lbl{font-size:8.5px; letter-spacing:.16em; text-transform:uppercase; color:var(--gold-deep); font-weight:700; margin-bottom:1.4mm}
.payrow table{font-size:9px; border-collapse:collapse}
.payrow table td{padding:.5mm 0; line-height:1.35}
.payrow table td:first-child{color:var(--muted); padding-right:4mm; white-space:nowrap}
.payrow table td:last-child{font-weight:600}
.payrow .qr{width:21mm; text-align:center; flex-shrink:0}
.payrow .qr img{width:20mm; height:auto; border:1px solid var(--line); border-radius:1.2mm}
.payrow .qr div{font-size:7px; color:var(--muted); letter-spacing:.06em; margin-top:.8mm}

.terms-sig{display:flex; gap:6mm; margin-top:4mm; flex:1}
.terms{flex:1; font-size:8.5px; color:var(--ink-soft); line-height:1.55}
.terms .lbl{font-size:9px; letter-spacing:.18em; text-transform:uppercase; color:var(--gold-deep); font-weight:700; margin-bottom:1.5mm}
.terms ol{padding-left:4mm}
.terms li{margin-bottom:.6mm}
.terms .decl{margin-top:2mm; font-style:italic; font-size:8.5px; color:var(--muted); line-height:1.5}
.sig{width:52mm; text-align:center; display:flex; flex-direction:column; justify-content:flex-end}
.sig .for{font-size:10px; font-weight:700; letter-spacing:.06em}
.sig .rep{font-size:9px; color:var(--ink-soft); margin-top:1mm}
.sig .line{border-top:1px solid var(--ink); margin-top:9mm; padding-top:1.5mm; font-size:9px; color:var(--muted); letter-spacing:.1em; text-transform:uppercase}

.foot-strip{
  margin-top:4.5mm; background:var(--gold); color:#FFF; font-size:9px; letter-spacing:.14em;
  text-transform:uppercase; text-align:center; padding:2.4mm; font-weight:500;
}
.pagefill{flex:1}

/* ---- WHY OAKCRAFT page ---- */
.p2-head{display:flex; justify-content:space-between; align-items:center}
.p2-head img{height:14mm}
.p2-head h2{font-family:Georgia,serif; font-weight:400; font-size:23px; letter-spacing:.3em; text-transform:uppercase}
.p2-intro{
  margin-top:3.5mm; font-family:Georgia,serif; font-style:italic; font-size:13px;
  color:var(--ink-soft); text-align:center; line-height:1.6;
}
.stat-band{
  margin-top:4mm; background:var(--ink); color:#F5EEDF; padding:6mm 7mm;
  display:flex; align-items:center; gap:8mm;
}
.stat-band .big{font-family:Georgia,serif; font-size:52px; color:#E8C888; line-height:1; white-space:nowrap}
.stat-band .big small{font-size:22px}
.stat-band .txt{font-size:10.5px; line-height:1.65}
.stat-band .txt b{color:#E8C888; letter-spacing:.14em; text-transform:uppercase; font-size:9.5px; display:block; margin-bottom:1.5mm}

.sysmaster{margin-top:4.5mm; border:1px solid var(--line); background:#FFFDF9}
.sm-head{
  background:linear-gradient(90deg, var(--gold) 0%, #C89345 100%); color:#FFF;
  display:flex; align-items:center; gap:4mm; padding:3mm 4.5mm;
}
.sm-head .sm-title{font-family:Georgia,serif; font-size:12.5px; letter-spacing:.18em; text-transform:uppercase}
.sm-head .sm-live{
  font-size:8px; letter-spacing:.14em; background:rgba(255,255,255,.18);
  border:1px solid rgba(255,255,255,.5); padding:1mm 2.4mm; border-radius:10px; font-weight:700;
}
.sm-head .sm-live:before{content:'●'; color:#8CFF9E; margin-right:1.2mm}
.sm-head .sm-stats{margin-left:auto; display:flex; gap:5mm; font-size:8.5px; letter-spacing:.08em; text-transform:uppercase}
.sm-head .sm-stats b{font-family:Georgia,serif; font-size:14px; display:block; text-align:center; letter-spacing:0}
.sm-grid{display:grid; grid-template-columns:repeat(3,1fr); gap:2.6mm; padding:3.2mm 4mm 2.5mm}
.sm-card{border:1px solid var(--line); border-top:2px solid var(--gold); background:#FFF; padding:2.4mm 2.8mm}
.sm-card h4{font-size:8px; letter-spacing:.14em; text-transform:uppercase; color:var(--gold-deep); margin-bottom:1.6mm; padding-bottom:1.2mm; border-bottom:1px solid var(--cream-deep)}
.sm-card .pr{font-size:8.6px; color:var(--ink-soft); padding:.55mm 0; line-height:1.35}
.sm-card .pr:before{content:'●'; color:var(--live); font-size:6px; margin-right:1.6mm; vertical-align:1px}
.sm-foot{
  font-size:8.6px; color:var(--muted); padding:0 4mm 3mm; line-height:1.5; text-align:center;
  font-style:italic; font-family:Georgia,serif;
}

.proof-row{display:grid; grid-template-columns:repeat(4,1fr); gap:3mm; margin-top:4.5mm}
.proof-row .pt{border:1px solid var(--line); border-top:2.5px solid var(--gold); padding:2.6mm; text-align:center}
.proof-row .pt .n{font-family:Georgia,serif; font-size:15px; color:var(--ink)}
.proof-row .pt .l{font-size:8px; letter-spacing:.08em; text-transform:uppercase; color:var(--muted); margin-top:1mm; line-height:1.45}

.founder{display:flex; gap:6mm; margin-top:5mm; align-items:center}
.fbook-wrap{width:42mm; text-align:center; flex-shrink:0}
.fbook-wrap img{
  width:42mm; display:block; border:1px solid var(--line);
  box-shadow:5px 5px 0 var(--cream-deep), 5px 5px 0 1px var(--line);
}
.fbook-wrap .fb-badge{
  margin-top:2.4mm; font-size:7.5px; letter-spacing:.14em; text-transform:uppercase;
  color:var(--gold-deep); font-weight:700; line-height:1.5;
}
.founder .ftxt{flex:1; font-size:10.5px; line-height:1.68; color:var(--ink-soft)}
.founder .ftxt .lbl{font-size:9.5px; letter-spacing:.2em; text-transform:uppercase; color:var(--gold-deep); font-weight:700; margin-bottom:2.4mm}
.fname-row{display:flex; align-items:center; gap:3.5mm; margin-bottom:2.6mm}
.fname-row img{width:21mm; height:21mm; object-fit:cover; border-radius:2px; border:1px solid var(--line-dark)}
.fname-row b{font-family:Georgia,serif; font-size:14.5px; color:var(--ink); display:block}
.fname-row .frole{font-size:8.5px; letter-spacing:.14em; text-transform:uppercase; color:var(--muted); margin-top:.8mm}

.gift-box{
  margin-top:4.5mm; border:1.5px solid var(--gold); background:rgba(180,128,47,.06);
  padding:3.2mm 5mm; text-align:center; font-family:Georgia,serif; font-size:12px; color:var(--ink);
}
.gift-box b{color:var(--gold-deep)}

/* ============ PRINT (fallback path) ============ */
@page{size:A4; margin:0}
@media print{
  body{background:#FFF}
  #toolbar,#editor,#pdfbar,#measurePage{display:none !important}
  #layout{padding-top:0}
  #preview{padding:0; height:auto; overflow:visible; display:block}
  #printArea{gap:0; display:block}
  .page{box-shadow:none; width:210mm; min-height:296mm; margin:0}
}
/* ============ MOBILE ============ */
#mobileTabs{display:none}
.pwrap{display:contents}
body.exporting .pwrap{display:block; height:auto !important}
body.exporting .page{transform:none !important}

@media (max-width:900px){
  /* toolbar becomes sticky + wrapping, buttons full-width touch targets */
  #toolbar{position:sticky; top:0; height:auto; flex-wrap:wrap; padding:10px 12px; gap:8px}
  #toolbar .brand{font-size:15px}
  #toolbar .brand span{display:none}
  #toolbar .qbadge{margin-left:auto; font-size:11px; padding:4px 9px}
  #toolbar .spacer{display:none}
  #toolbar .btn{flex:1; padding:11px 6px; font-size:11px; letter-spacing:.08em; text-align:center}

  #layout{display:block; padding-top:0}
  #editor{
    width:100%; min-width:0; height:auto; overflow:visible;
    border-right:none; padding:16px 14px 110px;
  }
  #editor input, #editor select, #editor textarea{font-size:16px; padding:10px}
  .addbtn{padding:13px}
  .item-card .rm{padding:6px}
  #preview{height:auto; overflow:visible; padding:12px 8px 110px; display:block}
  #printArea{display:block}

  /* pages scale to fit the phone width (set precisely by JS) */
  .pwrap{display:block; margin:0 auto 14px; overflow:visible}
  .page{transform-origin:top left; box-shadow:0 2px 14px rgba(36,26,16,.18)}

  /* view switching */
  body.mPreview #editor{display:none}
  body:not(.mPreview) #preview{display:none}

  /* bottom tab bar */
  #mobileTabs{
    display:flex; position:fixed; bottom:0; left:0; right:0; z-index:60;
    background:var(--ink); border-top:1px solid rgba(217,174,95,.35);
    padding-bottom:env(safe-area-inset-bottom);
  }
  .mtab{
    flex:1; padding:15px 8px; background:none; border:none; color:#CDBFA5;
    font-size:12px; letter-spacing:.14em; text-transform:uppercase; font-family:inherit; cursor:pointer;
  }
  .mtab.active{color:#E8C888; box-shadow:inset 0 -3px 0 var(--gold)}

  /* PDF-ready bar sits above the tabs on mobile */
  #pdfbar{top:auto; bottom:calc(52px + env(safe-area-inset-bottom)); border-top:1px solid #BFDCC0; border-bottom:none; flex-wrap:wrap}
}
</style>
</head>
<body>

<div id="toolbar">
  <div class="brand"><b>Oak</b>Craft <span style="opacity:.55">· Quotation Builder</span></div>
  <div class="qbadge" id="tbQno">—</div>
  <div class="spacer"></div>
  <button class="btn" onclick="newQuotation()">＋ New Quotation</button>
  <button class="btn" onclick="window.print()" title="Browser print fallback">Print</button>
  <button class="btn primary" id="dlBtn" onclick="downloadPDF()">⤓ Download PDF</button>
</div>

<div id="pdfbar">
  <span id="pdfmsg">✓ PDF generated.</span>
  <a id="pdfOpen" target="_blank" rel="noopener">Open PDF</a>
  <span style="opacity:.75">— if the download didn't start automatically, open it here and save.</span>
  <button class="close" onclick="document.getElementById('pdfbar').classList.remove('show')">✕</button>
</div>

<div id="mobileTabs">
  <button class="mtab active" id="tabEdit" onclick="setView('edit')">&#9998;&nbsp; Edit Details</button>
  <button class="mtab" id="tabPrev" onclick="setView('preview')">&#128196;&nbsp; Preview Invoice</button>
</div>

<div id="layout">
<!-- ================= EDITOR ================= -->
<aside id="editor">

  <div class="ed-sec">
    <h3>Quotation</h3>
    <div class="frow">
      <div class="f"><label>Number (auto — editable)</label><input type="number" id="inQno" oninput="S.qno=parseInt(this.value)||S.qno; R()"></div>
      <div class="f"><label>Date</label><input type="date" id="inDate" oninput="S.date=this.value; dateManual=true; R()"></div>
    </div>
    <div class="frow">
