/* ================= CALC ================= */
function calc(){
  let sub = 0;
  const rows = S.items.map(it=>{
    const net = it.price * (1 - (it.disc||0)/100);
    const amt = net * it.qty;
    sub += amt;
    return {...it, net, amt};
  });
  const fr = S.freightMode==='amount' ? (S.freight||0) : 0;
  const taxable = sub + fr;
  const isDelhi = S.state === 'Delhi';
  const cgst = isDelhi ? taxable * S.gst/200 : 0;
  const sgst = isDelhi ? taxable * S.gst/200 : 0;
  const igst = isDelhi ? 0 : taxable * S.gst/100;
  const pre = taxable + cgst + sgst + igst;
  const grand = Math.round(pre);
  const roundoff = grand - pre;
  return {rows, sub, fr, taxable, isDelhi, cgst, sgst, igst, roundoff, grand};
}

